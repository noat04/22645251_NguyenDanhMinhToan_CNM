<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
    <title>Chi tiết Sản phẩm</title>
</head>

<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">Chi tiết Sản phẩm</h3>
                        <a href="/products" class="btn btn-light btn-sm"><i class="fa fa-arrow-left"></i> Quay lại</a>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-5 text-center mb-3">
                                <% if(product.url_image) { %>
                                    <img src="<%= product.url_image %>" alt="<%= product.name %>"
                                        class="img-fluid rounded"
                                        style="max-height: 300px; object-fit: cover; border: 1px solid #ddd;" />
                                    <% } else { %>
                                        <div class="p-5 bg-light text-muted border rounded">
                                            <i class="fa fa-picture-o fa-3x mb-2"></i>
                                            <p>Chưa có ảnh</p>
                                        </div>
                                        <% } %>
                            </div>

                            <div class="col-md-7">
                                <h4 class="text-primary font-weight-bold mb-3">
                                    <%= product.name %>
                                </h4>
                                <table class="table table-borderless">
                                    <tbody>
                                        <tr>
                                            <th style="width: 40%">Mã ID:</th>
                                            <td class="text-muted">
                                                <%= product.id %>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Giá bán:</th>
                                            <td class="text-danger font-weight-bold">
                                                <%= product.price %> VNĐ
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Số lượng tồn:</th>
                                            <td><span class="badge badge-success" style="font-size: 14px;">
                                                    <%= product.unit_in_stock %>
                                                </span> sản phẩm</td>
                                        </tr>
                                    </tbody>
                                </table>

                                <div class="mt-4 pt-3 border-top">
                                    <a href="/products/edit/<%= product.id %>" class="btn btn-primary">
                                        <i class="fa fa-pencil"></i> Sửa sản phẩm
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
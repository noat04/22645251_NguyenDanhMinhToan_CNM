<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
    <title>Cập nhật Sản phẩm</title>
</head>

<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">Cập nhật Sản phẩm</h3>
                    </div>
                    <div class="card-body">
                        <form action="/products/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">

                            <div class="form-group mb-3">
                                <label for="name" class="font-weight-bold">Tên sản phẩm</label>
                                <input class="form-control" type="text" id="name" name="name"
                                    value="<%= product.name %>" required />
                            </div>

                            <div class="row">
                                <div class="col-md-6 form-group mb-3">
                                    <label for="price" class="font-weight-bold">Giá (VNĐ)</label>
                                    <input class="form-control" type="number" id="price" name="price"
                                        value="<%= product.price %>" min="0" required />
                                </div>
                                <div class="col-md-6 form-group mb-3">
                                    <label for="unit_in_stock" class="font-weight-bold">Số lượng tồn</label>
                                    <input class="form-control" type="number" id="unit_in_stock" name="unit_in_stock"
                                        value="<%= product.unit_in_stock %>" min="0" required />
                                </div>
                            </div>

                            <div class="form-group mb-4 border p-3 rounded bg-light">
                                <label for="url_image" class="font-weight-bold">Hình ảnh sản phẩm</label>

                                <% if(product.url_image) { %>
                                    <div class="mb-3">
                                        <p class="text-muted mb-1 small">Ảnh hiện tại:</p>
                                        <img src="<%= product.url_image %>" alt="Current Image"
                                            style="height: 100px; border-radius: 5px; border: 1px solid #ccc;">
                                    </div>
                                    <% } %>

                                        <input class="form-control-file" type="file" id="url_image" name="url_image"
                                            accept="image/*" />
                                        <small class="form-text text-muted mt-2">
                                            <i class="fa fa-info-circle"></i> Bỏ trống nếu bạn muốn giữ nguyên ảnh cũ.
                                            Chỉ chấp nhận (jpg, png, jpeg, gif).
                                        </small>
                            </div>

                            <div class="text-right mt-4">
                                <a href="/products" class="btn btn-secondary mr-2">Hủy bỏ</a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save"></i> Cập nhật thay đổi
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
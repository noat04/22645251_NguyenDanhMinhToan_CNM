<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
    <title>Quản lý Sản phẩm</title>
</head>

<body>
    <div class="container mt-5">
        <h1 class="text-center mb-4">Ứng dụng Quản lý Sản phẩm</h1>

        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
            <h2 class="title m-0">Danh sách Sản phẩm</h2>
            
            <form action="/products" method="GET" class="form-inline mx-auto my-2 my-lg-0">
                <div class="input-group">
                    <input type="text" name="keyword" class="form-control" placeholder="Nhập tên sản phẩm..." 
                           value="<%= typeof keyword !== 'undefined' ? keyword : '' %>">
                    <div class="input-group-append">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-search"></i> Tìm
                        </button>
                        <% if (typeof keyword !== 'undefined' && keyword) { %>
                            <a href="/products" class="btn btn-outline-danger" title="Hủy tìm kiếm">
                                <i class="fa fa-times"></i>
                            </a>
                        <% } %>
                    </div>
                </div>
            </form>

            <a href="/products/create" class="btn btn-success">
                <i class="fa fa-plus"></i> Thêm Sản phẩm
            </a>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover" id="products">
                <thead class="thead-dark">
                    <tr>
                        <th>Id</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá (VNĐ)</th>
                        <th>Số lượng tồn</th>
                        <th>Hình ảnh</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length> 0) { %>
                        <% products.forEach(function(product) { %>
                            <tr>
                                <td class="align-middle">
                                    <%= product.id %>
                                </td>
                                <td class="align-middle">
                                    <%= product.name %>
                                </td>
                                <td class="align-middle">
                                    <%= product.price %>
                                </td>
                                <td class="align-middle">
                                    <%= product.unit_in_stock %>
                                </td>
                                <td class="align-middle">
                                    <% if(product.url_image) { %>
                                        <img src="<%= product.url_image %>" alt="<%= product.name %>"
                                            style="width: 80px; height: 80px; object-fit: cover; border-radius: 5px;" />
                                        <% } else { %>
                                            <span class="text-muted">Chưa có ảnh</span>
                                            <% } %>
                                </td>
                                <td class="align-middle">
                                    <a href="/products/<%= product.id %>" class="btn btn-info btn-sm"
                                        title="Xem chi tiết">
                                        <i class="fa fa-eye"></i>
                                    </a>

                                    <a href="/products/edit/<%= product.id %>" class="btn btn-primary btn-sm"
                                        title="Sửa">
                                        <i class="fa fa-pencil"></i>
                                    </a>

                                    <form action="/products/delete/<%= product.id %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?');">
                                        <button type="submit" class="btn btn-danger btn-sm" title="Xóa">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <% if (typeof keyword !== 'undefined' && keyword) { %>
                                                Không tìm thấy sản phẩm nào có tên "<strong><%= keyword %></strong>".
                                            <% } else { %>
                                                Không có sản phẩm nào trong hệ thống.
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>

</html>
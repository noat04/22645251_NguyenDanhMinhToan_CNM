<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cập nhật Vé Sự Kiện</title>
</head>
<body>
    <h2>Cập nhật Vé Sự Kiện</h2>

    <form action="/tickets/edit/<%= ticket.id %>" method="POST" enctype="multipart/form-data">
        
        <p>
            <label for="eventName">Tên sự kiện:</label><br>
            <input type="text" id="eventName" name="eventName" value="<%= ticket.eventName %>" required>
        </p>

        <p>
            <label for="holderName">Tên khách hàng:</label><br>
            <input type="text" id="holderName" name="holderName" value="<%= ticket.holderName %>" required>
        </p>

        <p>
            <label for="category">Loại vé (Sẽ tự động tính lại giảm giá nếu thay đổi):</label><br>
            <select id="category" name="category" required>
                <option value="Standard" <%= ticket.category === 'Standard' ? 'selected' : '' %>>Standard (Không giảm giá)</option>
                <option value="VIP" <%= ticket.category === 'VIP' ? 'selected' : '' %>>VIP (Giảm 10% nếu mua từ 4 vé)</option>
                <option value="VVIP" <%= ticket.category === 'VVIP' ? 'selected' : '' %>>VVIP (Giảm 15% nếu mua từ 2 vé)</option>
            </select>
        </p>

        <p>
            <label for="quantity">Số lượng:</label><br>
            <input type="number" id="quantity" name="quantity" min="1" value="<%= ticket.quantity %>" required>
        </p>

        <p>
            <label for="pricePerTicket">Giá mỗi vé (VNĐ):</label><br>
            <input type="number" id="pricePerTicket" name="pricePerTicket" min="0" value="<%= ticket.pricePerTicket %>" required>
        </p>

        <p>
            <label for="eventDate">Ngày diễn ra:</label><br>
            <input type="date" id="eventDate" name="eventDate" value="<%= ticket.eventDate %>" required>
        </p>

        <p>
            <label for="status">Trạng thái:</label><br>
            <select id="status" name="status" required>
                <option value="Upcoming" <%= ticket.status === 'Upcoming' ? 'selected' : '' %>>Upcoming (Sắp diễn ra)</option>
                <option value="Sold" <%= ticket.status === 'Sold' ? 'selected' : '' %>>Sold (Đã bán)</option>
                <option value="Cancelled" <%= ticket.status === 'Cancelled' ? 'selected' : '' %>>Cancelled (Đã hủy)</option>
            </select>
        </p>

        <p>
            <label for="imageUrl">Hình ảnh sự kiện:</label><br>
            
            <% if(ticket.imageUrl) { %>
                <span>Ảnh hiện tại:</span><br>
                <img src="<%= ticket.imageUrl %>" alt="<%= ticket.eventName %>" style="height: 100px; border: 1px solid #ccc; margin-bottom: 10px;"><br>
            <% } %>

            <input type="file" id="imageUrl" name="imageUrl" accept="image/*"><br>
            <small><i>Bỏ trống nếu bạn muốn giữ nguyên ảnh cũ.</i></small>
        </p>

        <p>
            <button type="submit">Cập nhật thay đổi</button>
            <a href="/tickets"><button type="button">Hủy bỏ</button></a>
        </p>

    </form>
</body>
</html>
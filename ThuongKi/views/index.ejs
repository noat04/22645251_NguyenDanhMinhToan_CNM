<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách Vé</title>
    <style>
        /* CSS đơn giản tạo grid chứa các thẻ card */
        .card-container { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 20px; }
        .card { border: 1px solid #ccc; border-radius: 8px; padding: 15px; width: 250px; background: #f9f9f9; }
        .card img { width: 100%; height: 150px; object-fit: cover; border-radius: 5px; margin-bottom: 10px; }
        .card-title { margin: 0 0 10px 0; font-size: 18px; color: #333; }
        .card p { margin: 5px 0; font-size: 14px; }
        .badge { color: red; font-weight: bold; font-size: 12px; }
    </style>
</head>
<body>
    <h2>Danh sách Vé Sự kiện</h2>

    <form action="/tickets" method="GET" style="margin-bottom: 20px;">
        <input type="text" name="query" placeholder="Nhập tên sự kiện..." value="<%= typeof query !== 'undefined' ? query : '' %>">
        
        <select name="status">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Upcoming">Upcoming (Sắp diễn ra)</option>
            <option value="Sold">Sold (Đã bán)</option>
            <option value="Cancelled">Cancelled (Đã hủy)</option>
        </select>

        <button type="submit">Tìm & Lọc</button>
        <a href="/tickets/create"><button type="button"> + Thêm Vé Mới</button></a>
    </form>

    <hr>

    <div class="card-container">
        <% if (tickets && tickets.length > 0) { %>
            <% tickets.forEach(ticket => { %>
                <div class="card">
                    <% if (ticket.imageUrl) { %>
                        <img src="<%= ticket.imageUrl %>" alt="<%= ticket.eventName %>">
                    <% } else { %>
                        <div style="height: 150px; background: #ddd; text-align: center; line-height: 150px;">Chưa có ảnh</div>
                    <% } %>

                    <h3 class="card-title"><%= ticket.eventName %></h3>
                    <p><b>Khách hàng:</b> <%= ticket.holderName %></p>
                    <p><b>Trạng thái:</b> <%= ticket.status %></p>
                    <p><b>Thanh toán:</b> <%= ticket.finalAmount %> VNĐ</p>
                    <p class="badge">[<%= ticket.discountLabel %>]</p> <div style="margin-top: 15px;">
                        <a href="/tickets/<%= ticket.id %>"><button>Xem chi tiết</button></a>
                        <a href="/tickets/edit/<%= ticket.id %>"><button>Sửa</button></a>
                        <form action="/tickets/delete/<%= ticket.id %>" method="POST" style="display: inline;">
                            <button type="submit" onclick="return confirm('Bạn có chắc chắn muốn xóa vé này?');">Xóa</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <p>Không có vé nào phù hợp với tìm kiếm.</p>
        <% } %>
    </div>

</body>
</html>